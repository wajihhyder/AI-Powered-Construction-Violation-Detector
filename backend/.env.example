SECRET_KEY=your-super-secret-jwt-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

DATABASE_URL=sqlite:///./vioscan.db

GEOAPIFY_API_KEY=your-geoapify-api-key-here

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
AI_STREET_MODEL_PATH=../best_floor.pt
AI_STREET_MODEL_CONFIDENCE=0.15
AI_STREET_MODEL_IOU=0.45
AI_STREET_MODEL_MIN_FLOOR_CONFIDENCE=0.25
AI_STREET_MODEL_MIN_WIDTH_RATIO=0.4
AI_STREET_MODEL_FLOOR_GAP_RATIO=0.6
AI_STREET_MODEL_IMGSZ=960
AI_STREET_MODEL_AUGMENT=true

# Aerial encroachment YOLO building segmenter (Roboflow encroachment dataset).
AI_ENCROACHMENT_MODEL_PATH=../best_encroachment.pt
AI_ENCROACHMENT_CONFIDENCE=0.25
AI_ENCROACHMENT_IOU=0.45
AI_ENCROACHMENT_IMAGE_SPAN_M=300.0
AI_ENCROACHMENT_ROAD_BUFFER_M=4.0

AI_DEVICE=cpu

FRONTEND_URL=http://localhost:5173

# Set true if frontend/dist exists but you want API-only on :8000 (use Vite on :5173 for the UI).
# DISABLE_SPA_ON_API=true

# Printable notice (optional — blank lines become underscores in the PDF/HTML output)
NOTICE_REPLY_DAYS=7
NOTICE_OFFICE_LINE1=
NOTICE_OFFICE_LINE2=
NOTICE_CONTACT_LINE=
